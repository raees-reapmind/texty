platform :ios, '15.0'

ENV['COCOAPODS_DISABLE_STATS'] = '1'

# Search for podhelper in local project first, then fallback to Flutter SDK
podhelper_path = File.expand_path(File.join('Flutter', 'podhelper.rb'), __dir__)

if File.exist?(podhelper_path)
  require podhelper_path
else
  # Fallback to FLUTTER_ROOT env var which is available in GH Actions
  flutter_root = ENV['FLUTTER_ROOT']
  if flutter_root
    require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)
  else
    # Last resort: try to find it via Generated.xcconfig for local environments
    generated_xcconfig = File.expand_path(File.join('Flutter', 'Generated.xcconfig'), __dir__)
    if File.exist?(generated_xcconfig)
      flutter_root = File.foreach(generated_xcconfig).grep(/FLUTTER_ROOT=/).first.split('=').last.strip rescue nil
      if flutter_root
        require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)
      end
    end
  end
end

# Fail explicitly with a helpful message if podhelper still not loaded
unless respond_to?(:flutter_ios_podfile_setup)
  raise "podhelper not found. Please run 'flutter pub get' first or ensure FLUTTER_ROOT is set in your environment."
end

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end