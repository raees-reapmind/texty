# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = '1'

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

def flutter_install_all_ios_pods(ios_application_path = nil)
  native_additions_path = File.join(File.dirname(__FILE__), 'Flutter', 'podhelper.rb')
  require native_additions_path
  flutter_ios_podfile_setup
  parse_plugins_from_pubspec(ios_application_path)
  # Iterate over the plugins and install them as pods.
  pod 'Flutter', :path => File.join(File.dirname(__FILE__), 'Flutter')
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end
